      <collision>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="package://robot_arms/meshes/collision/finger-thin-prox.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
    </link> -->

    <!-- <link name="${prefix}finger1">
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="package://robot_arms/meshes/visual/modular_finger.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="Black">
          <color rgba="0.1 0.1 0.1 1" />
        </material>
      </visual>
      <collision>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="package://robot_arms/meshes/collision/modular_finger.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
    </link>

    <link name="${prefix}finger2">
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="package://robot_arms/meshes/visual/modular_finger.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="Black">
          <color rgba="0.1 0.1 0.1 1" />
        </material>
      </visual>
      <collision>
        <origin rpy="0 0 0" xyz="0 0 0"/>
