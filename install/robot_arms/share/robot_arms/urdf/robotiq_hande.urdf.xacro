<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">
  <xacro:macro name="robotiq_hande" params="prefix origin">
    
    <xacro:property name="param_file" value="$(find robot_arms)/config/gripper/hande_parameters.yaml" />
    <xacro:property name="gripper_props" value="${xacro.load_yaml(param_file)}"/>
    
    <xacro:property name="mass_val" value="${gripper_props['robotiq_hande']['mass']}" />
    <xacro:property name="ixx_val" value="${gripper_props['robotiq_hande']['inertia']['ixx']}" />
    <xacro:property name="upper_limit" value="${gripper_props['robotiq_hande']['limits']['upper_stroke']}" />
    <xacro:property name="max_effort" value="${gripper_props['robotiq_hande']['limits']['max_effort']}" />

    <joint name="${prefix}base_to_gripper" type="fixed">
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <parent link="${origin}"/>
      <child link="${prefix}base_link"/>
    </joint>

    <link name="${prefix}base_link">
      <inertial>
        <origin xyz="0 0 0.046" rpy="0 0 0"/>
        <mass value="${mass_val}"/>
        <inertia ixx="${ixx_val}" ixy="0.0" ixz="0.0" iyy="${ixx_val}" iyz="0.0" izz="${ixx_val}"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://robot_arms/meshes/visual/gripper.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="Black">
          <color rgba="0.1 0.1 0.1 1" />
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://robot_arms/meshes/collision/gripper.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
    </link>

    <link name="${prefix}jaw1_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.01"/>
        <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
      </inertial>
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="package://robot_arms/meshes/visual/jaw.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="grey">
          <color rgba="0.83 0.83 0.83 1" />
        </material>
      </visual>
      <collision>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="package://robot_arms/meshes/collision/jaw.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
    </link>

    <link name="${prefix}jaw2_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.01"/>
        <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
      </inertial>
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="package://robot_arms/meshes/visual/jaw.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="Grey">
          <color rgba="0.83 0.83 0.83 1" />
        </material>
      </visual>
      <collision>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="package://robot_arms/meshes/collision/jaw.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
    </link>

    <link name="${prefix}finger1">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.01"/>
        <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
      </inertial>
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="package://robot_arms/meshes/visual/finger.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="Black">
          <color rgba="0.1 0.1 0.1 1" />
        </material>
      </visual>
      <collision>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="package://robot_arms/meshes/collision/finger.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
    </link>

    <link name="${prefix}finger2">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.01"/>
        <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
      </inertial>
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="package://robot_arms/meshes/visual/finger.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="Black">
          <color rgba="0.1 0.1 0.1 1" />
        </material>
      </visual>
      <collision>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="package://robot_arms/meshes/collision/finger.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
    </link>

    <joint name="${prefix}joint" type="prismatic">
      <origin rpy="0 0 0" xyz="0 0 0.0952"/>
      <parent link="${prefix}base_link"/>
      <child link="${prefix}jaw1_link"/>
      <axis xyz="1 0 0"/>
      <limit effort="${max_effort}" lower="0.0" upper="${upper_limit}" velocity="0.15"/>
    </joint>

    <joint name="${prefix}base_to_${prefix}jaw2_link" type="prismatic">
      <origin rpy="0 0 ${pi}" xyz="0 0 0.0952"/>
      <parent link="${prefix}base_link"/>
      <child link="${prefix}jaw2_link"/>
      <axis xyz="1 0 0"/>
      <limit effort="${max_effort}" lower="0.0" upper="${upper_limit}" velocity="0.15"/>
      <mimic joint="${prefix}joint" multiplier="1" offset="0"/>
    </joint>

    <joint name="${prefix}jaw1_to_finger1" type="fixed">
      <origin rpy="0 0 0" xyz="0 0 0.0325"/>
      <parent link="${prefix}jaw1_link"/>
      <child link="${prefix}finger1"/>
    </joint>

    <joint name="${prefix}jaw2_to_finger2" type="fixed">
      <origin rpy="0 0 0" xyz="0 0 0.0325"/>
      <parent link="${prefix}jaw2_link"/>
      <child link="${prefix}finger2"/>
    </joint>
    
  </xacro:macro>
</robot>