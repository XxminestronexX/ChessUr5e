          <mesh filename="package://robot_arms/meshes/collision/modular_finger.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
    </link> -->

    <joint name="${prefix}joint" type="prismatic">
      <origin rpy="0 0 0" xyz="0 0 0.0952"/>
      <parent link="${prefix}base_link"/>
      <child link="${prefix}jaw1_link"/>
      <axis xyz="1 0 0"/>
      <limit effort="130" lower="0.0" upper="0.025" velocity="0.15"/>
    </joint>

    <joint name="${prefix}base_to_${prefix}jaw2_link" type="prismatic">
      <origin rpy="0 0 ${pi}" xyz="0 0 0.0952"/>
      <parent link="${prefix}base_link"/>
      <child link="${prefix}jaw2_link"/>
      <axis xyz="1 0 0"/>
      <limit effort="130" lower="0.0" upper="0.025" velocity="0.15"/>
      <mimic joint="${prefix}joint" multiplier="1" offset="0"/>
    </joint>

    <joint name="${prefix}jaw1_to_finger1" type="fixed">
      <origin rpy="0 0 0" xyz="0 0 0.0325"/>
      <parent link="${prefix}jaw1_link"/>
      <child link="${prefix}finger1"/>
    </joint>

    <joint name="${prefix}jaw2_to_finger2" type="fixed">
      <origin rpy="0 0 0" xyz="0 0 0.0325"/>
      <parent link="${prefix}jaw2_link"/>
      <child link="${prefix}finger2"/>
    </joint>

   <transmission name="${prefix}joint_trans">
      <type>transmission_interface/SimpleTransmission</type>
      <joint name="${prefix}joint">
        <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      </joint>
      <actuator name="${prefix}joint_motor">
        <mechanicalReduction>1</mechanicalReduction>
      </actuator>
    </transmission>
    
  </xacro:macro>
</robot>
